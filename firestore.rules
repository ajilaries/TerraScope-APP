rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read, write: if request.auth != null
                          && request.auth.uid == userId;

      match /emergencyContacts/{document=**} {
        allow read, write: if request.auth != null
                            && request.auth.uid == userId;
      }

      match /schedules/{document=**} {
        allow read, write: if request.auth != null
                            && request.auth.uid == userId;
      }

      match /tasks/{document=**} {
        allow read, write: if request.auth != null
                            && request.auth.uid == userId;
      }

      match /reminders/{document=**} {
        allow read, write: if request.auth != null
                            && request.auth.uid == userId;
      }
    }

    match /emergencyContacts/{document} {
      allow read, write: if request.auth != null
                         && request.resource.data.userId == request.auth.uid;
    }

    match /safetyHistory/{document} {
      allow read, write: if request.auth != null
                         && request.resource.data.userId == request.auth.uid;
    }

    match /weather/{document} {
      allow read: if request.auth != null;
    }

    match /emergencyServices/{document} {
      allow read: if true;
    }

    match /userSettings/{userId} {
      allow read, write: if request.auth != null
                          && request.auth.uid == userId;
    }

    match /farmerData/{userId} {
      allow read, write: if request.auth != null
                          && request.auth.uid == userId;
    }

    match /commuteData/{userId} {
      allow read, write: if request.auth != null
                          && request.auth.uid == userId;
    }

    match /dailyPlanner/{userId} {
      allow read, write: if request.auth != null
                          && request.auth.uid == userId;
    }

    match /travelerData/{userId} {
      allow read, write: if request.auth != null
                          && request.auth.uid == userId;
    }

    match /careData/{userId} {
      allow read, write: if request.auth != null
                          && request.auth.uid == userId;
    }

    match /aiPredictions/{document} {
      allow read: if request.auth != null;
    }

    // 8 Core Collections from FIRESTORE_SCHEMA.md
    match /weather_history/{document} {
      allow read, create: if request.auth != null;
      allow write, update, delete: if false; // Append-only
    }
    match /weather_data/{document} {
      allow read, write: if request.auth != null;
    }
    match /user_devices/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /prediction/{document} {
      allow read, write: if request.auth != null;
    }
    match /historical_data/{document} {
      allow read: if request.auth != null;
      allow write: if false; // Admin/cron only
    }
    match /anomalies/{document} {
      allow read: if request.auth != null;
      allow create: if request.auth != null; // Detection service
    }
    match /alerts/{document} {
      allow read: if request.auth != null;
      allow create: if false; // Notification service
    }
    match /users/{document} {
      allow read, write: if request.auth != null && request.auth.uid == document;
    }

    match /aqi/{document} {
      allow read: if request.auth != null;
    }

    match /radar/{document} {
      allow read: if request.auth != null;
    }

    match /soil/{document} {
      allow read: if request.auth != null;
    }

    match /crop/{document} {
      allow read: if request.auth != null;
    }

    match /locationCache/{document} {
      allow read: if request.auth != null;
    }

    match /nearbyServices/{document} {
      allow read: if request.auth != null;
    }
  }
}
